        { "editorMode": "code", "expr": "sum(rate(bookstore_idempotency_cleanup_rows_deleted_sum[15m])) / clamp_min(sum(rate(bookstore_idempotency_cleanup_rows_deleted_count[15m])), 0.001)", "legendFormat": "rows deleted avg", "range": true, "refId": "B" }
