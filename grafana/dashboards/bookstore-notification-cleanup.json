      "targets": [
        { "editorMode": "code", "expr": "sum(rate(notifications_events_received_total[5m]))", "legendFormat": "events received", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(notifications_events_duplicates_skipped_total[5m]))", "legendFormat": "duplicates skipped", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(notifications_emails_sent_total[5m]))", "legendFormat": "emails sent", "range": true, "refId": "C" },
        { "editorMode": "code", "expr": "sum(rate(notifications_emails_failed_total[5m]))", "legendFormat": "emails failed", "range": true, "refId": "D" }
      ],
      "title": "Notification Consumer Rates",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
