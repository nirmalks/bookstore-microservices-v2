      "targets": [
        { "editorMode": "code", "expr": "1000 * (sum(rate(notifications_email_processing_time_seconds_sum[5m])) / clamp_min(sum(rate(notifications_email_processing_time_seconds_count[5m])), 0.001))", "legendFormat": "email processing avg", "range": true, "refId": "A" }
      ],
      "title": "Notification Processing Time",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
