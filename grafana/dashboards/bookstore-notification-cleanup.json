      "targets": [
        { "editorMode": "code", "expr": "sum(rate(bookstore_idempotency_cleanup_runs_total[15m]))", "legendFormat": "cleanup runs", "range": true, "refId": "A" },
        { "editorMode": "code", "expr": "sum(rate(bookstore_idempotency_cleanup_failed_total[15m]))", "legendFormat": "cleanup failed", "range": true, "refId": "B" },
        { "editorMode": "code", "expr": "sum(rate(bookstore_idempotency_cleanup_lock_skipped_total[15m]))", "legendFormat": "cleanup lock skipped", "range": true, "refId": "C" }
      ],
      "title": "Cleanup Job Rates",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "unit": "ms" }, "overrides": [] },
